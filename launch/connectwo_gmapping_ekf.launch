<launch>
  <!--
    Gmapping with EKF sensor fusion

    This launch file combines:
    1. EKF sensor fusion (/odom + /imu -> /odometry/filtered)
    2. Gmapping SLAM using the filtered odometry

    Usage:
      roslaunch connectwo_bringup connectwo_gmapping_ekf.launch
  -->

  <!-- Arguments -->
  <arg name="model" default="burger" doc="model type [burger, waffle, waffle_pi]"/>
  <arg name="configuration_basename" default="turtlebot3_lds_2d.lua"/>
  <arg name="set_base_frame" default="base_footprint"/>
  <arg name="set_odom_frame" default="odom"/>
  <arg name="set_map_frame"  default="map"/>

  <!-- Launch EKF for sensor fusion -->
  <include file="$(find connectwo_bringup)/launch/connectwo_ekf.launch"/>

  <!-- Remap gmapping to use filtered odometry -->
  <node pkg="gmapping" type="slam_gmapping" name="turtlebot3_slam_gmapping" output="screen">
    <param name="base_frame" value="$(arg set_base_frame)"/>
    <param name="odom_frame" value="$(arg set_odom_frame)"/>
    <param name="map_frame"  value="$(arg set_map_frame)"/>

    <!-- Use filtered odometry instead of raw /odom -->
    <remap from="scan" to="scan"/>
    <remap from="odom" to="/odometry/filtered"/>

    <!-- Gmapping parameters -->
    <rosparam command="load" file="$(find turtlebot3_slam)/config/gmapping_params.yaml" />
  </node>

</launch>
